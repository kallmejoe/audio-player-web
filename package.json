{
  "name": "soundflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev:renderer": "vite --port=3000 --host=0.0.0.0",
    "dev:electron": "node scripts/build-electron.mjs && electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"sleep 2 && npm run dev:electron\"",
    "build:electron": "node scripts/build-electron.mjs",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npm run build:electron",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:arm": "npm run build && electron-builder --mac --arm64",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.soundflow.app",
    "productName": "SoundFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*.cjs",
      "dist-electron/**/*.js.map",
      "assets/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "hardenedRuntime": true
    },
    "dmg": {
      "title": "SoundFlow",
      "icon": "assets/icon.png",
      "iconSize": 128
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "music-metadata": "^11.13.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
